# Copy to .env and fill in for production. All are optional in dev:
# without them the API uses SQLite, fixed OTP 123456, and dev defaults.

# PostgreSQL (production database)
DATABASE_URL=postgres://user:password@host:5432/homeflow

# Auth
JWT_SECRET=generate-a-long-random-string
ADMIN_PASSWORD=change-the-seeded-admin-password

# Real OTP SMS via MSG91 (https://msg91.com — get authkey + an OTP template)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Server
PORT=4000
